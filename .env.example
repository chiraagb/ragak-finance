# Database
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql+asyncpg://ragak_user:change_me@localhost:5432/ragak
DATABASE_URL_SYNC=postgresql+psycopg2://ragak_user:change_me@localhost:5432/ragak

# Cache / Queue
REDIS_PASSWORD=change_me_redis_password
REDIS_URL=redis://:change_me_redis_password@localhost:6379/0

# External APIs
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here  # Used for embeddings only

# Auth
JWT_SECRET_KEY=generate_256_bit_random_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Frontend
API_BASE_URL=http://localhost:8000
